---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { books } from '../../content/books';
import type { Book } from '../../content/books';

export function getStaticPaths() {
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;

const statusLabel: Record<string, string> = {
  querying: 'Currently Querying',
  writing: 'In Progress',
  upcoming: 'Upcoming',
};
---

<BaseLayout title={book.title} description={book.tagline} theme={book.theme}>
  <section class="book-hero">
    <div class="container">
      <div class="book-hero__grid">
        <div class="book-hero__image">
          <img src={book.image} alt={book.title} />
        </div>
        <div class="book-hero__content">
          <span class="book-hero__genre">{book.genre}</span>
          <h1 class="animate-in animate-in--delay-1">{book.title}</h1>
          <p class="book-hero__tagline animate-in animate-in--delay-2">{book.tagline}</p>
          <span class="book-hero__status animate-in animate-in--delay-2">{statusLabel[book.status]}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="book-body">
    <div class="container container--narrow">
      <div class="book-body__content animate-in animate-in--delay-3">
        <h2>About the Story</h2>
        <p>{book.description}</p>

        <div class="book-detail">
          <h3>Characters</h3>
          <p class="book-detail__value">{book.characters}</p>
        </div>

        <div class="book-detail">
          <h3>Genre</h3>
          <p class="book-detail__value">{book.genre}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="book-back">
    <div class="container container--narrow">
      <a href="/#books" class="back-link">&larr; All Books</a>
    </div>
  </section>
</BaseLayout>

<style>
  .book-hero {
    padding-top: calc(80px + var(--space-2xl));
    padding-bottom: var(--space-xl);
  }

  .book-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .book-hero__image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .book-hero__genre {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent-text);
    margin-bottom: var(--space-md);
  }

  .book-hero__content h1 {
    margin-bottom: var(--space-lg);
  }

  .book-hero__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
    max-width: 50ch;
  }

  .book-hero__status {
    display: inline-block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-text);
    border: 1px solid var(--color-accent);
    padding: 6px 16px;
    border-radius: 20px;
  }

  .book-body {
    padding: var(--space-lg) 0 var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .book-body__content h2 {
    font-size: 1.6rem;
    margin-bottom: var(--space-md);
  }

  .book-body__content p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: var(--space-lg);
    max-width: none;
  }

  .book-detail {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
  }

  .book-detail h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 500;
  }

  .book-detail__value {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-text);
    margin-bottom: 0;
  }

  .book-back {
    padding-bottom: var(--space-lg);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent-text);
  }

  @media (max-width: 768px) {
    .book-hero__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .book-hero__image img {
      max-width: 350px;
      margin: 0 auto;
    }

    .book-hero__tagline {
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
